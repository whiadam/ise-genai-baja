# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored and should NEVER be committed.
#
# When running on GCP (Cloud Run / App Engine) the app picks up credentials
# automatically via Application Default Credentials, so secrets.toml is only
# needed for local development.

[gcp]
project_id      = "your-gcp-project-id"
dataset         = "campus_event_tracker"
vertex_location = "us-central1"
gemini_model    = "gemini-2.5-flash"

# Optional: paste a service-account JSON key if ADC is not configured locally.
# [gcp_service_account]
# type                        = "service_account"
# project_id                  = "your-gcp-project-id"
# private_key_id              = "..."
# private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# client_email                = "...@....iam.gserviceaccount.com"
# client_id                   = "..."
# auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
# token_uri                   = "https://oauth2.googleapis.com/token"
